{
  "name": "stadium-sense",
  "version": "1.0.0",
  "description": "StadiumSense - AI-powered accessibility for stadiums",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && .\\venv\\Scripts\\activate && python main.py",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && .\\venv\\Scripts\\activate && pip install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
